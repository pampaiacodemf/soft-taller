# ══════════════════════════════════════════════════════════
# Environment Variables - SaaS ERP Taller
# Copia este archivo a .env y completa los valores
# ══════════════════════════════════════════════════════════

# ── Base de Datos (Supabase PostgreSQL) ───────────────────
# Obtenés estas URLs en: https://supabase.com/dashboard → Project → Settings → Database
# La "Transaction pooler" URL es para DATABASE_URL (funciona con Prisma en serverless/Vercel)
# La "Session pooler" o "Direct connection" URL es para DIRECT_URL (usado por migraciones)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ── Autenticación (NextAuth) ──────────────────────────────
# Generá un secreto con: openssl rand -base64 32
# O en Windows PowerShell: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-al-menos-32-caracteres"
# En desarrollo local usá http://localhost:3000
# En producción (Vercel) usá tu dominio real: https://tu-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ── Archivos (Uploads) ────────────────────────────────────
UPLOAD_DIR="uploads"

# ── AWS S3 (opcional, para imágenes en producción) ────────
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="sa-east-1"
# AWS_BUCKET_NAME=""

# ── AFIP/ARCA Web Services (opcional) ────────────────────
# AFIP_CUIT=""
# AFIP_CERT_PATH=""
# AFIP_KEY_PATH=""
# AFIP_ENVIRONMENT="testing"  # "testing" | "production"
