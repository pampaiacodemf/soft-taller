# Environment Variables - SaaS ERP Taller (Neon + Netlify)
# Copy this file to .env and fill in your values

# ── Database (Neon.tech) ──────────────────────────────────
# Use the Prisma connection string from Neon Dashboard
DATABASE_URL="postgresql://user:password@ep-cool-darkness-123456.sa-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# ── Authentication ────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Configuration ──────────────────────────────────────────
NODE_ENV="production"
