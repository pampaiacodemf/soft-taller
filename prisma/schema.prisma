// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────
// TENANT (Multi-tenancy root)
// ─────────────────────────────────────────────────────────

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  cuit         String?
  address      String?
  phone        String?
  email        String?
  logoUrl      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subscription Subscription?
  users        User[]
  customers    Customer[]
  products     Product[]
  workOrders   WorkOrder[]
  invoices     Invoice[]
  expenses     Expense[]
  categories      ProductCategory[]
  currentAccounts CurrentAccount[]
  budgets      Budget[]
  cashShifts   CashShift[]
  deviceDict   DeviceDictionary[]
}

// ─────────────────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────────────────

model Subscription {
  id            String           @id @default(cuid())
  tenantId      String           @unique
  plan          String @default("BASIC")
  expiresAt     DateTime
  daysRemaining Int              @default(30)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  tenantId      String
  name          String
  email         String
  password      String
  role          String     @default("SALES")
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrders    WorkOrder[] @relation("AssignedTechnician")
  reports       TechnicalReport[]
  expenses      Expense[]
  openedShifts  CashShift[] @relation("ShiftOpenedBy")
  closedShifts  CashShift[] @relation("ShiftClosedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────

model Customer {
  id             String         @id @default(cuid())
  tenantId       String
  name           String
  cuit           String?
  dni            String?
  email          String?
  phone          String?
  address        String?
  ivaCondition   String         @default("CONSUMIDOR_FINAL")
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrders     WorkOrder[]
  invoices       Invoice[]
  budgets        Budget[]
  currentAccount CurrentAccount?

  @@index([tenantId])
  @@index([tenantId, name])
}

// ─────────────────────────────────────────────────────────
// INVENTORY / PRODUCTS
// ─────────────────────────────────────────────────────────

model ProductCategory {
  id       String    @id @default(cuid())
  tenantId String
  name     String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
}

model Product {
  id           String          @id @default(cuid())
  tenantId     String
  categoryId   String?
  name         String
  brand        String?
  model        String?
  barcode      String?         // EAN-13 or similar
  description  String?
  costPrice    Float           @default(0)
  salePrice    Float           @default(0)
  ivaRate      Float           @default(21)
  stock        Int             @default(0)
  minStock     Int             @default(1)
  unit         String          @default("unidad")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  saleItems    SaleItem[]
  budgetItems  BudgetItem[]

  @@index([tenantId])
  @@index([tenantId, barcode])
  @@index([tenantId, name])
}

// ─────────────────────────────────────────────────────────
// WORK ORDERS
// ─────────────────────────────────────────────────────────

model WorkOrder {
  id                 String          @id @default(cuid())
  tenantId           String
  customerId         String
  technicianId       String?
  orderNumber        Int
  status             String          @default("INGRESADO")
  deviceType         String          // Notebook, PC, Impresora, etc.
  brand              String?
  model              String?
  serial             String?
  problemDescription String
  accessoryList      String?         // Mouse, cargador, etc.
  estimatedDelivery  DateTime?
  deliveredAt        DateTime?
  internalNotes      String?
  budgetAmount       Float?
  budgetApprovedAt   DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer        @relation(fields: [customerId], references: [id])
  technician         User?           @relation("AssignedTechnician", fields: [technicianId], references: [id])
  photos             WorkOrderPhoto[]
  technicalReport    TechnicalReport?
  budget             Budget?
  statusHistory      WorkOrderStatusHistory[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

model WorkOrderPhoto {
  id          String    @id @default(cuid())
  workOrderId String
  url         String
  type        String @default("RECEPTION")
  caption     String?
  createdAt   DateTime  @default(now())

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model WorkOrderStatusHistory {
  id          String          @id @default(cuid())
  workOrderId String
  fromStatus  String?
  toStatus    String
  note        String?
  changedAt   DateTime        @default(now())

  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model TechnicalReport {
  id            String    @id @default(cuid())
  workOrderId   String    @unique
  technicianId  String?
  diagnosis     String
  solution      String?
  partsUsed     String?
  laborHours    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  technician    User?     @relation(fields: [technicianId], references: [id])
}

// ─────────────────────────────────────────────────────────
// BUDGET (Presupuesto)
// ─────────────────────────────────────────────────────────

model Budget {
  id          String       @id @default(cuid())
  tenantId    String
  customerId  String?
  workOrderId String?      @unique
  budgetNumber Int
  
  validUntil  DateTime?
  subtotal    Float
  ivaAmount   Float
  total       Float
  notes       String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer?    @relation(fields: [customerId], references: [id])
  workOrder   WorkOrder?   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  items       BudgetItem[]

  @@index([tenantId])
  @@index([tenantId, customerId])
}

model BudgetItem {
  id          String   @id @default(cuid())
  budgetId    String
  productId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  ivaRate     Float
  subtotal    Float

  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────
// INVOICES (Facturación ARCA/AFIP)
// ─────────────────────────────────────────────────────────

model Invoice {
  id              String      @id @default(cuid())
  tenantId        String
  customerId      String
  invoiceType     String
  puntoVenta      Int         @default(1)
  invoiceNumber   Int
  invoiceDate     DateTime    @default(now())
  paymentMethod   String      @default("CASH") // CASH, DEBIT, CREDIT, TRANSFER, CURRENT_ACCOUNT
  subtotal        Float
  ivaAmount       Float
  total           Float
  afipCae         String?
  afipCaeExpiry   DateTime?
  afipResult      String?       // Full AFIP response stored as JSON
  notes           String?
  isPaid          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer    @relation(fields: [customerId], references: [id])
  items           SaleItem[]
  accountMovement CurrentAccountMovement?

  @@unique([tenantId, invoiceType, puntoVenta, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
}

model SaleItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  ivaRate     Float
  subtotal    Float

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────
// CURRENT ACCOUNTS (Cuentas Corrientes)
// ─────────────────────────────────────────────────────────

model CurrentAccount {
  id         String                   @id @default(cuid())
  tenantId   String
  customerId String @unique
  balance    Float                  @default(0)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  
  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  movements  CurrentAccountMovement[]
  receipts   Receipt[]

  @@unique([tenantId, customerId])
  @@index([tenantId])
}

model CurrentAccountMovement {
  id               String         @id @default(cuid())
  currentAccountId String
  invoiceId        String?        @unique
  type             String
  amount           Float
  balanceAfter     Float
  concept          String
  date             DateTime       @default(now())

  currentAccount   CurrentAccount @relation(fields: [currentAccountId], references: [id], onDelete: Cascade)
  invoice          Invoice?       @relation(fields: [invoiceId], references: [id])
}

model Receipt {
  id               String         @id @default(cuid())
  currentAccountId String
  receiptNumber    Int
  amount           Float
  concept          String?
  paymentMethod    String?        // Efectivo, Transferencia, Tarjeta
  date             DateTime       @default(now())
  createdAt        DateTime       @default(now())

  currentAccount   CurrentAccount @relation(fields: [currentAccountId], references: [id], onDelete: Cascade)

  @@unique([currentAccountId, receiptNumber])
}

// ─────────────────────────────────────────────────────────
// EXPENSES (Gastos)
// ─────────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String?
  category    String
  description String
  amount      Float
  date        DateTime @default(now())
  receipt     String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
}

// ─────────────────────────────────────────────────────────
// CASH REGISTER (Caja)
// ─────────────────────────────────────────────────────────

model CashShift {
  id           String    @id @default(cuid())
  tenantId     String
  openedById   String
  closedById   String?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  initialCash  Float     @default(0)
  finalCash    Float?    // The actual counted cash when closing
  notes        String?
  
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  openedBy     User      @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedBy     User?     @relation("ShiftClosedBy", fields: [closedById], references: [id])
  movements    CashMovement[]

  @@index([tenantId])
  @@index([tenantId, openedAt])
}

model CashMovement {
  id           String    @id @default(cuid())
  shiftId      String
  type         String    // IN, OUT
  amount       Float
  method       String    // CASH, TRANSFER, CREDIT, DEBIT, CURRENT_ACCOUNT
  concept      String    // "Venta", "Gasto", "Ingreso Manual", "Retiro"
  referenceId  String?   // ID of invoice, receipt, or expense
  createdAt    DateTime  @default(now())

  shift        CashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
}

// ─────────────────────────────────────────────────────────
// DICTIONARY / AUTOCOMPLETE
// ─────────────────────────────────────────────────────────

model DeviceDictionary {
  id        String   @id @default(cuid())
  tenantId  String
  type      String   // "TYPE", "BRAND", "MODEL"
  value     String
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, value])
  @@index([tenantId, type])
}
