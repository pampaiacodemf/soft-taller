# ─── Dependencies ────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js build output ────────────────────────────────
/.next/
/out/

# ─── Production build ────────────────────────────────────
/build

# ─── Environment variables (NEVER commit these!) ─────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Prisma local SQLite database ────────────────────────
prisma/*.db
prisma/*.db-journal

# ─── Vercel ──────────────────────────────────────────────
.vercel

# ─── Debug logs ──────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS files ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript build info ───────────────────────────────
*.tsbuildinfo
next-env.d.ts
